<?xml version="1.0"?>
<odoo><data>

    <record model="ir.ui.view" id="view_ctkm_inventory_import_wizard_form">
        <field name="name">ctkm.inventory.import.wizard.form</field>
        <field name="model">ctkm.inventory.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Tem/Tag">
                <sheet>
                    <group>
                        <field name="upload_file"
                            filename="filename"
                            options="{'accepted_file_extensions': '.xlsx'}"/>
                        <field name="filename" invisible="1"/>
                        <field name="program_id"/>
                        <field name="import_date"/>
                        <field name="replace_existing"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button string="Hủy" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_ctkm_inventory_import_wizard">
        <field name="name">Import Tem/Tag</field>
        <field name="res_model">ctkm.inventory.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ctkm_inventory_import_wizard_form"/>
        <field name="target">new</field>
    </record>

    <record model="ir.actions.server" id="server_action_ctkm_inventory_import">
        <field name="name">Import Tem/Tag</field>
        <field name="model_id" ref="model_ctkm_inventory_tem_tag"/>
        <field name="binding_model_id" ref="model_ctkm_inventory_tem_tag"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = env.ref('ctkm_inventory.action_ctkm_inventory_import_wizard').read()[0]</field>
        <field name="group_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

</data></odoo>
