<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record model="res.groups.privilege" id="res_groups_privilege_ctkm">
            <field name="name">Chương trình khuyến mãi</field>
            <field name="sequence">19</field>
            <field name="category_id" ref="base.module_category_marketing"/>
        </record>

        <record id="group_ctkm_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_ctkm"/>
        </record>

        <record id="group_ctkm_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="res_groups_privilege_ctkm"/>
            <field name="implied_ids" eval="[(4, ref('group_ctkm_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- CTKM users/managers: full visibility -->
        <record id="ctkm_program_rule_user" model="ir.rule">
            <field name="name">CTKM: user xem toàn bộ chương trình</field>
            <field name="model_id" ref="model_ctkm_program"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ctkm_user'))]"/>
        </record>

        <!-- Internal users without CTKM rights: only programs they are notified of / responsible for -->
        <record id="ctkm_program_rule_notify_recipient" model="ir.rule">
            <field name="name">CTKM: người nhận thông báo được xem CTKM</field>
            <field name="model_id" ref="model_ctkm_program"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('notify_line_ids.notify_employee_ids.user_id', 'in', [user.id])]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Tasks: user chỉ thấy việc của mình; manager thấy tất cả -->
        <record id="ctkm_task_rule_user" model="ir.rule">
            <field name="name">CTKM Task: user xem công việc của mình</field>
            <field name="model_id" ref="model_ctkm_task"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ctkm_user'))]"/>
        </record>
        <record id="ctkm_task_rule_manager" model="ir.rule">
            <field name="name">CTKM Task: manager xem toàn bộ</field>
            <field name="model_id" ref="model_ctkm_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ctkm_manager'))]"/>
        </record>
    </data>
</odoo>
