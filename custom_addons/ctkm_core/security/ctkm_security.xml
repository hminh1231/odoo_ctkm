<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record model="res.groups.privilege" id="res_groups_privilege_ctkm">
            <field name="name">Chương trình khuyến mãi</field>
            <field name="sequence">19</field>
            <field name="category_id" ref="base.module_category_marketing"/>
        </record>

        <record id="group_ctkm_user" model="res.groups">
            <field name="name">User</field>
            <field name="sequence">10</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_ctkm"/>
        </record>

        <record id="group_ctkm_store" model="res.groups">
            <field name="name">Store</field>
            <field name="sequence">15</field>
            <field name="implied_ids" eval="[(4, ref('group_ctkm_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_ctkm"/>
        </record>

        <record id="group_ctkm_approver" model="res.groups">
            <field name="name">Approver</field>
            <field name="sequence">18</field>
            <field name="implied_ids" eval="[(4, ref('group_ctkm_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_ctkm"/>
        </record>

        <record id="group_ctkm_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="sequence">20</field>
            <field name="privilege_id" ref="res_groups_privilege_ctkm"/>
            <field name="implied_ids" eval="[(4, ref('group_ctkm_store')), (4, ref('group_ctkm_approver'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="ctkm_program_detail_line_recipient_rule" model="ir.rule">
            <field name="name">CTKM Detail: chương trình được thông báo</field>
            <field name="model_id" ref="model_ctkm_program_detail_line"/>
            <field name="groups" eval="[(4, ref('group_ctkm_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="domain_force">['|', ('program_id.user_id', '=', user.id), ('program_id.notify_line_ids.notify_employee_ids.user_id', '=', user.id)]</field>
        </record>

        <record id="ctkm_program_detail_line_manager_rule" model="ir.rule">
            <field name="name">CTKM Detail: quản trị xem tất cả</field>
            <field name="model_id" ref="model_ctkm_program_detail_line"/>
            <field name="groups" eval="[(4, ref('group_ctkm_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
