<?xml version="1.0"?>
<odoo><data>

    <!-- Form View -->
    <record model="ir.ui.view" id="view_ctkm_program_form">
        <field name="name">ctkm.program.form</field>
        <field name="model">ctkm.program</field>
        <field name="arch" type="xml">
            <form string="Chương trình khuyến mãi">
                <header>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <widget name="web_ribbon" text="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="kanban_state" widget="statusbar" class="ms-auto float-end"/>
                    <div class="oe_title">
                        <label for="name" string="Tên chương trình"/>
                        <h1><field class="text-break" options="{'line_breaks': False}" widget="text" name="name" placeholder="VD: Chương trình giảm giá mùa hè"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="date_begin" string="Ngày" widget="daterange" options="{'end_date_field': 'date_end'}"/>
                            <field name="date_end" invisible="1"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_quick_create': True}"/>
                        </group>
                        <group name="right_program_details">
                            <field name="organizer_id"/>
                            <field name="user_id" widget="many2one_avatar_user" domain="[('share', '=', False)]"/>
                            <field name="company_id" groups="base.group_multi_company" placeholder="Visible to all"/>
                            <field name="address_id" context="{'show_address': 1}" placeholder="Online nếu không đặt"/>
                            <field name="event_url" invisible="address_id" widget="url" placeholder='VD: "https://www.example.com"'/>
                            <label for="seats_limited" string="Giới hạn đăng ký"/>
                            <div>
                                <field name="seats_limited"/>
                                <span invisible="not seats_limited" required="not seats_limited">
                                   đến <field name="seats_max" class="oe_inline o_input_9ch"/> Người tham gia
                                </span>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả" name="description">
                            <field name="description" placeholder="Mô tả chi tiết chương trình khuyến mãi..."/>
                        </page>
                        <page string="Phạm vi thông báo" name="notify_scope">
                            <div class="mb-2">
                                <button name="action_send_discuss_notification" type="object"
                                    string="Gửi tin" class="btn-primary"
                                    icon="fa-paper-plane"/>
                            </div>
                            <field name="notify_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="stt" string="Số thứ tự" readonly="1"/>
                                    <field name="sequence" column_invisible="1"/>
                                    <field name="mien"/>
                                    <field name="store_code_id" string="Mã cửa hàng" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="job_id" string="Chức vụ" options="{'no_create': True}"/>
                                    <field name="notify_employee_ids" widget="many2many_tags"
                                        domain="[('active', '=', True), ('mien', '=', mien)]"
                                        options="{'no_create': True, 'no_quick_create': True}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Detail" name="detail_approver" groups="ctkm_core.group_ctkm_approver">
                            <field name="approver_detail_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="stt" readonly="1"/>
                                    <field name="sequence" column_invisible="1"/>
                                    <field name="notification_date"/>
                                    <field name="notification_file"/>
                                    <field name="store_code_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="responsible_employee_id" options="{'no_create': True}"/>
                                    <field name="allocated_time"/>
                                    <field name="processing_date"/>
                                    <field name="work_content"/>
                                    <field name="excel_file_status"
                                        decoration-success="excel_file_status == 'processed'"
                                        decoration-muted="excel_file_status == 'not_processed'"/>
                                    <field name="completion_date"/>
                                    <field name="result_ok"/>
                                    <field name="manager_confirmed"/>
                                    <field name="result_note"/>
                                    <field name="support_request"/>
                                </list>
                            </field>
                        </page>
                        <page string="Detail" name="detail_store" groups="ctkm_core.group_ctkm_store">
                            <field name="store_detail_line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="stt" readonly="1"/>
                                    <field name="sequence" column_invisible="1"/>
                                    <field name="notification_date"/>
                                    <field name="notification_file"/>
                                    <field name="store_code_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="product_name"/>
                                    <field name="quantity"/>
                                    <field name="tag_confirmed"/>
                                    <field name="receive_status"
                                        decoration-success="receive_status == 'received'"
                                        decoration-muted="receive_status == 'not_received'"/>
                                    <field name="confirmation_note"/>
                                    <field name="processing_status"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ghi chú &amp; Tài liệu" name="program_notes">
                            <group>
                                <group string="Nhãn chương trình">
                                    <field name="badge_format"/>
                                    <field name="badge_image" widget="image"
                                        options="{'accepted_file_extensions': 'image/*'}"/>
                                </group>
                                <group string="Tài liệu gửi kèm thông báo">
                                    <div class="text-muted mb-2" colspan="2">
                                        PDF, Word hoặc Excel — gửi kèm khi bấm <b>Gửi tin</b>.
                                    </div>
                                    <field name="notify_document_ids" widget="many2many_binary" nolabel="1" colspan="2"
                                        options="{'accepted_file_extensions': '.pdf,.doc,.docx,.xls,.xlsx'}"/>
                                </group>
                                <group>
                                    <label for="ticket_instructions" string="Hướng dẫn vé"/>
                                    <br/>
                                    <field nolabel="1" colspan="2" name="ticket_instructions"
                                        placeholder="VD: Cách đến sự kiện, thời gian đóng cửa..."/>
                                </group>
                                <group>
                                    <label for="note" string="Ghi chú"/>
                                    <br/>
                                    <field nolabel="1" colspan="2" name="note"
                                        placeholder="Thêm ghi chú nội bộ (việc cần làm, thông tin liên hệ...)"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record model="ir.ui.view" id="view_ctkm_program_tree">
        <field name="name">ctkm.program.list</field>
        <field name="model">ctkm.program</field>
        <field name="arch" type="xml">
            <list string="Chương trình khuyến mãi"
                multi_edit="1"
                sample="1">
                <field name="name"/>
                <field name="address_id" readonly="1"/>
                <field name="organizer_id" readonly="1" optional="hide"/>
                <field name="user_id" readonly="1" widget="many2one_avatar_user"/>
                <field name="company_id" groups="base.group_multi_company" readonly="1" optional="show"/>
                <field name="date_begin" readonly="1"/>
                <field name="date_end" readonly="1"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="hide"/>
                <field name="stage_id" readonly="1"/>
                <field name="message_needaction" readonly="1" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record model="ir.ui.view" id="view_ctkm_program_search">
        <field name="name">ctkm.program.search</field>
        <field name="model">ctkm.program</field>
        <field name="arch" type="xml">
            <search string="Chương trình khuyến mãi">
                <field name="name" string="Tên chương trình"/>
                <field name="user_id"/>
                <field name="stage_id"/>
                <filter string="Chương trình của tôi" name="myprograms" help="Chương trình của tôi" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Đang diễn ra" name="ongoing"
                    domain="[('date_end', '&gt;=', 'now')]" help="Chương trình đang diễn ra" />
                <separator/>
                <filter string="Đã lưu trữ" name="filter_inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <group>
                    <filter string="Người phụ trách" name="responsible" context="{'group_by': 'user_id'}"/>
                    <filter string="Giai đoạn" name="stage_id" context="{'group_by': 'stage_id'}"/>
                    <filter string="Ngày bắt đầu" name="date_begin" domain="[]" context="{'group_by': 'date_begin'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="action_ctkm_program_view">
       <field name="name">Chương trình khuyến mãi</field>
       <field name="path">ctkm-programs</field>
       <field name="res_model">ctkm.program</field>
       <field name="view_mode">list,form</field>
       <field name="search_view_id" ref="view_ctkm_program_search"/>
       <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Tạo chương trình khuyến mãi
          </p><p>
            Quản lý các chương trình khuyến mãi của bạn.
          </p>
       </field>
    </record>

    <record id="menu_ctkm_program" model="ir.ui.menu">
        <field name="action" ref="action_ctkm_program_view"/>
    </record>

</data></odoo>
