<?xml version="1.0"?>
<odoo><data>

    <!-- Stage List View -->
    <record model="ir.ui.view" id="view_ctkm_stage_tree">
        <field name="name">ctkm.stage.list</field>
        <field name="model">ctkm.stage</field>
        <field name="arch" type="xml">
            <list string="Giai đoạn" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="pipe_end"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <!-- Stage Action -->
    <record model="ir.actions.act_window" id="action_ctkm_stage_view">
       <field name="name">Giai đoạn</field>
       <field name="res_model">ctkm.stage</field>
       <field name="view_mode">list,form</field>
       <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Tạo giai đoạn mới
          </p>
       </field>
    </record>

    <record id="menu_ctkm_stage" model="ir.ui.menu">
        <field name="action" ref="action_ctkm_stage_view"/>
    </record>

    <!-- Tag List View -->
    <record model="ir.ui.view" id="view_ctkm_tag_tree">
        <field name="name">ctkm.tag.list</field>
        <field name="model">ctkm.tag</field>
        <field name="arch" type="xml">
            <list string="Nhãn" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Tag Action -->
    <record model="ir.actions.act_window" id="action_ctkm_tag_view">
       <field name="name">Nhãn</field>
       <field name="res_model">ctkm.tag</field>
       <field name="view_mode">list,form</field>
       <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Tạo nhãn mới
          </p>
       </field>
    </record>

    <record id="menu_ctkm_tag" model="ir.ui.menu">
        <field name="action" ref="action_ctkm_tag_view"/>
    </record>

</data></odoo>
